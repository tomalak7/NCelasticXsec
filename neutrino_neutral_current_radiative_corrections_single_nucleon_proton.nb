Cell[BoxData[
 RowBox[{
  RowBox[{"sigma", "[", 
   RowBox[{
   "E\[Nu]_", ",", "Q2_", ",", "GF_", ",", "M_", ",", "gM_", ",", "gE_", ",", 
    "fA_", ",", "fT_", ",", "\[Eta]_"}], "]"}], ":=", 
  RowBox[{
   FractionBox[
    SuperscriptBox["GF", "2"], 
    RowBox[{"2", "\[Pi]"}]], 
   FractionBox[
    SuperscriptBox["M", "2"], 
    SuperscriptBox["E\[Nu]", "2"]], 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Tau]", "=", 
        FractionBox["Q2", 
         RowBox[{"4", 
          SuperscriptBox["M", "2"]}]]}], ",", 
       RowBox[{"\[Nu]", "=", 
        RowBox[{
         RowBox[{"M", " ", "E\[Nu]"}], "-", 
         FractionBox["Q2", "4"]}]}], ",", 
       RowBox[{"A", "=", 
        RowBox[{
         RowBox[{"\[Tau]", " ", 
          SuperscriptBox["gM", "2"]}], "-", 
         SuperscriptBox["gE", "2"], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", "\[Tau]"}], ")"}], 
          SuperscriptBox["fA", "2"]}], "-", 
         RowBox[{"4", "\[Tau]", 
          RowBox[{"(", 
           RowBox[{"1", "+", "\[Tau]"}], ")"}], 
          SuperscriptBox["fT", "2"]}]}]}], ",", 
       RowBox[{"B", "=", 
        RowBox[{"4", " ", "\[Tau]", " ", "fA", " ", "gM"}]}], ",", 
       RowBox[{"C", "=", 
        RowBox[{
         RowBox[{"\[Tau]", " ", 
          SuperscriptBox["gM", "2"]}], "+", 
         SuperscriptBox["gE", "2"], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", "\[Tau]"}], ")"}], 
          SuperscriptBox["fA", "2"]}], "+", 
         RowBox[{"4", "\[Tau]", 
          RowBox[{"(", 
           RowBox[{"1", "+", "\[Tau]"}], ")"}], 
          SuperscriptBox["fT", "2"]}]}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"\[Tau]", " ", "A"}], "+", 
      RowBox[{"\[Eta]", 
       FractionBox["\[Nu]", 
        SuperscriptBox["M", "2"]], " ", "B"}], "+", 
      RowBox[{
       FractionBox[
        SuperscriptBox["\[Nu]", "2"], 
        SuperscriptBox["M", "4"]], 
       FractionBox["C", 
        RowBox[{"1", "+", "\[Tau]"}]]}]}]}], "]"}]}]}]], "Input",
