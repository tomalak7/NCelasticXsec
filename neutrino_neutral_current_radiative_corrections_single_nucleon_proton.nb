Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"soft", "[", 
    RowBox[{"\[Beta]_", ",", "\[Mu]S_", ",", "\[CapitalDelta]E_", ",", "Z_"}],
     "]"}], ":=", 
   RowBox[{
    RowBox[{"soft", "[", 
     RowBox[{"\[Beta]", ",", "\[Mu]S", ",", "\[CapitalDelta]E", ",", "Z"}], 
     "]"}], "=", 
    RowBox[{"1", "+", 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["Z", "2"], 
        RowBox[{"alpha", "[", "\[Mu]S", "]"}]}], "\[Pi]"], 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            FractionBox["1", 
             RowBox[{"2", "\[Beta]"}]], 
            RowBox[{"Log", "[", 
             FractionBox[
              RowBox[{"1", "+", "\[Beta]"}], 
              RowBox[{"1", "-", "\[Beta]"}]], "]"}]}]}], ")"}], 
         RowBox[{"Log", "[", 
          FractionBox["\[Mu]S", 
           RowBox[{"2", "\[CapitalDelta]E"}]], "]"}]}], "+", 
        RowBox[{
         FractionBox["1", "\[Beta]"], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"PolyLog", "[", 
            RowBox[{"2", ",", 
             FractionBox[
              RowBox[{"1", "-", "\[Beta]"}], 
              RowBox[{"1", "+", "\[Beta]"}]]}], "]"}], "-", 
           FractionBox[
            SuperscriptBox["\[Pi]", "2"], "6"]}], ")"}]}], "+", 
        RowBox[{
         FractionBox["1", 
          RowBox[{"2", "\[Beta]"}]], 
         RowBox[{"Log", "[", 
          FractionBox[
           RowBox[{"1", "+", "\[Beta]"}], 
           RowBox[{"1", "-", "\[Beta]"}]], "]"}], 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"Log", "[", 
            FractionBox[
             RowBox[{
              SqrtBox[
               RowBox[{"1", "-", 
                SuperscriptBox["\[Beta]", "2"]}]], 
              RowBox[{"(", 
               RowBox[{"1", "+", "\[Beta]"}], ")"}]}], 
             RowBox[{"4", 
              SuperscriptBox["\[Beta]", "2"]}]], "]"}]}], ")"}]}]}], 
       ")"}]}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"solution", "[", 
    RowBox[{"\[Beta]_", ",", "Z_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"solution", "[", 
     RowBox[{"\[Beta]", ",", "Z"}], "]"}], "=", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"H", "'"}], "[", "\[Mu]x", "]"}], "*", 
          FractionBox["\[Mu]x", "2"]}], "\[Equal]", 
         RowBox[{
          RowBox[{"-", 
           SuperscriptBox["Z", "2"]}], 
          FractionBox[
           RowBox[{"alpha", "[", "\[Mu]x", "]"}], "\[Pi]"], 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{
             FractionBox["1", 
              RowBox[{"2", "\[Beta]"}]], 
             RowBox[{"Log", "[", 
              FractionBox[
               RowBox[{"1", "+", "\[Beta]"}], 
               RowBox[{"1", "-", "\[Beta]"}]], "]"}]}]}], ")"}], 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{
             FractionBox["5", "9"], 
             FractionBox[
              RowBox[{"alpha", "[", "\[Mu]x", "]"}], "\[Pi]"], 
             RowBox[{"nf", "[", "\[Mu]x", "]"}]}]}], ")"}], 
          RowBox[{"H", "[", "\[Mu]x", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"H", "[", "\[Mu]H", "]"}], "==", "1."}]}], "}"}], ",", "H", ",", 
      RowBox[{"{", 
       RowBox[{"\[Mu]x", ",", 
        FractionBox["\[Mu]S", "2"], ",", 
        RowBox[{"2", "\[Mu]H"}]}], "}"}], ",", 
      RowBox[{"Method", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"\"\<DiscontinuityProcessing\>\"", "\[Rule]", "True"}], 
        "}"}]}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
