Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"alpha", "[", "\[Mu]_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"\[Mu]", "<", "me"}], ",", "\[Alpha]0", ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "<", "m\[Mu]"}], ",", 
       RowBox[{
        RowBox[{"xme", "[", 
         RowBox[{"Log", "[", 
          SuperscriptBox["\[Mu]", "2"], "]"}], "]"}], "/.", 
        RowBox[{"sme", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"\[Mu]", "<", "m\[Pi]"}], ",", 
         RowBox[{
          RowBox[{"xmmu", "[", 
           RowBox[{"Log", "[", 
            SuperscriptBox["\[Mu]", "2"], "]"}], "]"}], "/.", 
          RowBox[{"smmu", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"\[Mu]", "<", "mK"}], ",", 
           RowBox[{
            RowBox[{"x\[Pi]", "[", 
             RowBox[{"Log", "[", 
              SuperscriptBox["\[Mu]", "2"], "]"}], "]"}], "/.", 
            RowBox[{"sm\[Pi]", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"\[Mu]", "<", "m\[Rho]"}], ",", 
             RowBox[{
              RowBox[{"xK", "[", 
               RowBox[{"Log", "[", 
                SuperscriptBox["\[Mu]", "2"], "]"}], "]"}], "/.", 
              RowBox[{"smK", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"\[Mu]", "<", "mc"}], ",", 
               RowBox[{"xhad", "[", 
                RowBox[{"Log", "[", 
                 SuperscriptBox["\[Mu]", "2"], "]"}], "]"}], ",", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"\[Mu]", "<", "m\[Tau]"}], ",", 
                 RowBox[{
                  RowBox[{"xc", "[", 
                   RowBox[{"Log", "[", 
                    SuperscriptBox["\[Mu]", "2"], "]"}], "]"}], "/.", 
                  RowBox[{"s", "[", 
                   RowBox[{"[", "1", "]"}], "]"}]}], ",", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"\[Mu]", "<", "mb"}], ",", 
                   RowBox[{
                    RowBox[{"xc\[Tau]", "[", 
                    RowBox[{"Log", "[", 
                    SuperscriptBox["\[Mu]", "2"], "]"}], "]"}], "/.", 
                    RowBox[{"sc\[Tau]", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], ",", 
                   RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"\[Mu]", ">", "mb"}], ",", 
                    RowBox[{
                    RowBox[{"xb", "[", 
                    RowBox[{"Log", "[", 
                    SuperscriptBox["\[Mu]", "2"], "]"}], "]"}], "/.", 
                    RowBox[{"sx", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}]}], "]"}]}], 
                "]"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nf", "[", "\[Mu]_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"\[Mu]", "<", "me"}], ",", "0", ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "<", "m\[Mu]"}], ",", "1.", ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"\[Mu]", "<", "m\[Pi]"}], ",", "2.", ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"\[Mu]", "<", "mK"}], ",", 
           RowBox[{"2.", "+", 
            FractionBox["1", "4"]}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"\[Mu]", "<", "m\[Rho]"}], ",", 
             RowBox[{"2.", "+", 
              FractionBox["1", "2"]}], ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"\[Mu]", "<", "mc"}], ",", 
               RowBox[{
                FractionBox["5", "2"], "+", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   FractionBox["16", "3"], "-", 
                   FractionBox["5", "2"]}], ")"}], 
                 FractionBox[
                  RowBox[{"\[Mu]", "-", "m\[Rho]"}], 
                  RowBox[{"mc", "-", "m\[Rho]"}]]}]}], ",", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"\[Mu]", "<", "m\[Tau]"}], ",", 
                 FractionBox["16", "3"], ",", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"\[Mu]", "<", "mb"}], ",", 
                   FractionBox["19", "3"], ",", 
                   RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"\[Mu]", ">", "mb"}], ",", 
                    FractionBox["20", "3"]}], "]"}]}], "]"}]}], "]"}]}], 
              "]"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]}], 
  ";"}]}], "Input",
